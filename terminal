<!DOCTYPE html>
<html class="dark" lang="zh-CN">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport"/>
    <title>SYS_SPEAR_MASTER_V1.1</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <style>
        body { font-family: 'Space Grotesk', sans-serif; background-color: #0e0e0e; color: #ffffff; background-image: linear-gradient(rgba(0, 252, 64, 0.03) 1px, transparent 1px); background-size: 100% 3px; -webkit-text-size-adjust: 100%; min-height: max(884px, 100dvh); }
        .glow-text { text-shadow: 0 0 10px rgba(0, 252, 64, 0.8); }
        .scanline-box { position: relative; overflow: hidden; }
        .scanline-box::after { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06)); background-size: 100% 2px, 3px 100%; pointer-events: none; z-index: 10; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Form elements reset for Terminal look */
        select, input[type="number"] { background: transparent; border: none; border-bottom: 1px solid rgba(0, 252, 64, 0.3); color: #00fc40; padding: 4px 0; font-size: 12px; outline: none; appearance: none; font-weight: bold; }
        select option { background: #131313; color: #00fc40; }
        input:focus, select:focus { border-bottom: 1px solid #00fc40; box-shadow: 0 1px 0 0 #00fc40; }
        input:disabled, select:disabled { opacity: 0.5; cursor: not-allowed; border-color: rgba(255, 255, 255, 0.1); color: #888; }
        
        input[type="range"] { -webkit-appearance: none; width: 100%; background: transparent; }
        input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; height: 16px; width: 16px; border-radius: 0; background: #00fc40; cursor: pointer; border: 1px solid #fff; box-shadow: 0 0 5px rgba(0,252,64,0.5); }
        input[type="range"]::-webkit-slider-runnable-track { width: 100%; height: 4px; cursor: pointer; background: #262626; border: 1px solid #131313; }
        input[type="range"]:disabled::-webkit-slider-thumb { background: #555; box-shadow: none; }
        
        canvas { display: block; width: 100%; height: 100%; }
        
        /* Export Canvas (Hidden) */
        #exportCanvas { position: absolute; left: -9999px; top: 0; width: 600px; background: #0e0e0e; color: #00fc40; padding: 20px; font-family: 'Space Grotesk', sans-serif; box-sizing: border-box; border: 2px solid #00fc40; }
        .exp-title { font-size: 24px; font-weight: bold; border-bottom: 2px solid #00fc40; padding-bottom: 10px; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: baseline; text-shadow: 0 0 5px #00fc40;}
        .exp-section { margin-bottom: 15px; border: 1px solid rgba(0, 252, 64, 0.3); padding: 10px; background: rgba(0,252,64,0.05);}
        .exp-row { display: flex; justify-content: space-between; margin-bottom: 5px; font-size: 12px; }
        .exp-row span:last-child { font-weight: bold; color: #fff; }
    </style>
    <script id="tailwind-config">
        tailwind.config = { darkMode: "class", theme: { extend: { colors: { primary: "#9cff93", "primary-container": "#00fc40", background: "#0e0e0e", surface: "#131313", "surface-container": "#1a1919", "surface-container-high": "#201f1f", error: "#ff7351", "on-surface": "#ffffff", "on-surface-variant": "#adaaaa", "outline-variant": "#494847" } } } }
    </script>
</head>
<body class="bg-background text-on-background min-h-screen flex flex-col md:flex-row antialiased selection:bg-primary-container selection:text-black">

<nav class="font-['Space_Grotesk'] text-sm uppercase tracking-widest h-full w-64 fixed left-0 top-0 z-40 hidden md:flex flex-col bg-surface border-r border-outline-variant/30">
    <div class="p-6 border-b border-outline-variant/30 flex items-center gap-3">
        <span class="material-symbols-outlined text-primary-container font-black glow-text">terminal</span>
        <span class="text-primary-container font-black text-lg glow-text">MH_OPS</span>
    </div>
    <div class="flex-1 overflow-y-auto py-4 flex flex-col gap-1">
        <a class="flex items-center gap-3 bg-primary text-background font-bold px-4 py-3 mx-2" href="#">
            <span class="material-symbols-outlined">settings_input_component</span> HARDWARE
        </a>
        <button onclick="autoOptimize()" class="w-full text-left flex items-center gap-3 text-on-surface-variant px-4 py-3 mx-2 hover:bg-surface-container hover:text-primary transition-all">
            <span class="material-symbols-outlined">bolt</span> AUTO_SYNC
        </button>
        <button onclick="exportConfig()" class="w-full text-left flex items-center gap-3 text-on-surface-variant px-4 py-3 mx-2 hover:bg-surface-container hover:text-primary transition-all">
            <span class="material-symbols-outlined">save</span> EXPORT_DAT
        </button>
        <button onclick="resetAll()" class="w-full text-left flex items-center gap-3 text-error px-4 py-3 mx-2 hover:bg-surface-container transition-all">
            <span class="material-symbols-outlined">delete</span> PURGE_MEM
        </button>
    </div>
    <div class="p-4 border-t border-outline-variant/30 text-xs text-on-surface-variant/50 flex justify-between items-center">
        <span>SYS.STAT: ONLINE</span>
        <select id="langSwitcher" onchange="changeLanguage(this.value)" class="bg-transparent border-none text-[10px] w-auto">
            <option value="zh">ZH</option><option value="en">EN</option><option value="ja">JA</option>
        </select>
    </div>
</nav>

<div class="flex-1 flex flex-col md:ml-64 w-full h-screen overflow-hidden">
    <header class="font-['Space_Grotesk'] tracking-tighter uppercase text-xs md:text-sm fixed top-0 left-0 w-full z-50 flex justify-between items-center px-4 h-12 md:h-16 md:pl-72 bg-surface border-b border-outline-variant/30 shadow-[0_0_15px_rgba(0,252,64,0.05)]">
        <div class="flex items-center gap-3 text-primary">
            <span class="material-symbols-outlined">radar</span>
            <span class="font-bold tracking-widest uppercase glow-text" data-i18n="app_name">SYS_SPEAR_MASTER_V1.1</span>
        </div>
        <div class="flex items-center gap-4 text-[10px] text-primary animate-pulse">
            DATA_LINK_SECURE
        </div>
    </header>

    <main class="flex-1 mt-12 md:mt-16 mb-[60px] md:mb-0 p-4 md:p-6 overflow-y-auto no-scrollbar pb-24">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 max-w-7xl mx-auto">
            
            <div class="col-span-1 md:col-span-12 bg-surface-container p-4 border-l-2 border-primary scanline-box">
                <div class="flex justify-between items-start">
                    <div>
                        <h1 class="text-xl text-primary font-bold uppercase tracking-widest glow-text">TARGET_ACQ_MODULE</h1>
                        <p class="text-[10px] text-on-surface-variant uppercase mt-1">LAT: 34.0522° N | LNG: 118.2437° W | PHYSICS: ENABLED</p>
                    </div>
                    <div class="flex gap-2 items-center">
                        <span class="w-2 h-2 bg-primary-container animate-pulse shadow-[0_0_8px_#00fc40]"></span>
                        <span class="text-xs text-primary-container uppercase font-bold tracking-wider">SYNCED</span>
                    </div>
                </div>
            </div>

            <div class="col-span-1 md:col-span-4 flex flex-col gap-4">
                
                <div class="bg-surface p-4 border border-outline-variant/30 relative group">
                    <h2 class="text-xs font-bold text-on-surface uppercase tracking-wider mb-4 border-b border-outline-variant/30 pb-2 text-primary">CORE_ARCHITECTURE</h2>
                    <div class="space-y-4">
                        <div>
                            <div class="flex justify-between items-end mb-1">
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-widest" data-i18n="gun_length">BARREL_LEN [CM]</label>
                                <span class="text-primary font-bold text-sm glow-text" id="gunLenVal">100 cm</span>
                            </div>
                            <input type="range" id="gunLen" min="60" max="150" step="5" value="100" oninput="dynamicLimit(true); updateAll();">
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-widest block mb-1" data-i18n="sys_type">SYS_TYPE</label>
                                <select id="sysType" onchange="updateSysUI(); dynamicLimit(true); updateAll();" class="w-full">
                                    <option value="standard" data-i18n="opt_standard">Standard</option>
                                    <option value="roller" data-i18n="opt_roller">Roller</option>
                                    <option value="double_roller" data-i18n="opt_double_roller">Double Roller</option>
                                    <option value="invert" data-i18n="opt_invert">Invert</option>
                                </select>
                            </div>
                            <div>
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-widest block mb-1" data-i18n="gun_shape">SHAPE</label>
                                <select id="gunShape" onchange="updateAll()" class="w-full">
                                    <option value="al_tube" data-i18n="shape_al">AL Tube</option>
                                    <option value="carbon_cuttlefish" selected data-i18n="shape_carbon">Carbon CF</option>
                                    <option value="wood_cuttlefish" data-i18n="shape_wood_c">Wood CF</option>
                                    <option value="wood_block" data-i18n="shape_wood_b">Wood Block</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-surface p-4 border border-outline-variant/30">
                    <h2 class="text-xs font-bold text-on-surface uppercase tracking-wider mb-4 border-b border-outline-variant/30 pb-2 text-primary">PROPULSION_MATRIX</h2>
                    <div class="space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-widest block mb-1" data-i18n="band_brand">BRAND</label>
                                <select id="bandBrand" onchange="updateModels(); updateAll();" class="w-full"><option value="sigalsub" selected>Sigalsub</option><option value="primeline">Primeline</option><option value="roballen">Rob Allen</option></select>
                            </div>
                            <div>
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-widest block mb-1" data-i18n="band_model">MODEL/DIA</label>
                                <select id="bandModel" onchange="updateAll()" class="w-full"></select>
                            </div>
                        </div>
                        
                        <div class="grid grid-cols-2 gap-4">
                            <div id="uiStandard">
                                <label class="text-[10px] text-on-surface-variant uppercase block mb-1" data-i18n="band_count">COUNT</label>
                                <select id="stdCount" onchange="updateAll()" class="w-full"><option value="1">1</option><option value="2" selected>2</option><option value="3">3</option><option value="4">4</option></select>
                            </div>
                            <div id="uiRoller" style="display:none;"><label class="text-[10px] text-on-surface-variant uppercase block mb-1">COUNT</label><select disabled class="w-full"><option>1 MAIN</option></select></div>
                            <div id="uiDoubleRoller" style="display:none;"><label class="text-[10px] text-on-surface-variant uppercase block mb-1">COUNT</label><select disabled class="w-full"><option>2 MAIN</option></select></div>
                            <div id="uiInvert" style="display:none;">
                                <label class="text-[10px] text-on-surface-variant uppercase block mb-1" data-i18n="invert_sub">SUB_COUNT</label>
                                <select id="invSubCount" onchange="updateAll()" class="w-full"><option value="1">1</option><option value="2" selected>2</option><option value="3">3</option><option value="4">4</option></select>
                            </div>
                            
                            <div>
                                <label class="text-[10px] text-on-surface-variant uppercase block mb-1" data-i18n="wishbone">WISHBONE (AUTO: <input type="checkbox" id="autoWishbone" checked onchange="updateAll()" style="accent-color: #00fc40;">)</label>
                                <div class="flex items-center gap-2">
                                    <input type="range" id="wishboneLen" min="0" max="25" step="1" value="10" oninput="document.getElementById('autoWishbone').checked = false; updateAll();">
                                    <span id="wishboneLenVal" class="text-xs text-primary font-bold">10</span>
                                </div>
                            </div>
                        </div>

                        <div id="uiExtension" style="display:none;">
                            <label class="text-[10px] text-on-surface-variant uppercase block mb-1" data-i18n="ext_line">EXT_LINE (AUTO: <input type="checkbox" id="autoExt" checked onchange="updateAll()" style="accent-color: #00fc40;">)</label>
                            <div class="flex items-center gap-2">
                                <input type="range" id="extLen" min="0" max="80" step="1" value="10" oninput="document.getElementById('autoExt').checked = false; updateAll();">
                                <span id="extLenVal" class="text-xs text-primary font-bold">10</span>
                            </div>
                        </div>

                        <div class="p-2 border border-error/30 bg-error/5 relative mt-2">
                            <label class="text-[10px] text-error uppercase flex justify-between">
                                <span data-i18n="tuning_mode">INV_TUNING (REV_CALC)</span>
                                <input type="checkbox" id="lockBand" onchange="toggleTuningMode(); updateAll();" style="accent-color: #ff7351;">
                            </label>
                            <div id="tuningInputs" style="display:none; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 8px;">
                                <div><label class="text-[9px] text-error">MAIN_CUT(CM)</label><input type="number" id="inputMainBand" value="50" step="1" oninput="updateAll()" class="w-full !border-error !text-error"></div>
                                <div id="tuningSubBox" style="display:none;"><label class="text-[9px] text-error">SUB_CUT(CM)</label><input type="number" id="inputSubBand" value="40" step="1" oninput="updateAll()" class="w-full !border-error !text-error"></div>
                            </div>
                        </div>

                        <div>
                            <div class="flex justify-between items-end mb-1">
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-widest" data-i18n="stretch_ratio">STRETCH_RATIO</label>
                                <span class="text-primary font-bold text-sm glow-text" id="stretchRatioVal">3.3 x</span>
                            </div>
                            <input type="range" id="stretchRatio" min="2.0" max="5.0" step="0.1" value="3.3" oninput="updateAll()">
                            <span id="ratioWarnTxt" class="text-[10px] text-error mt-1 block"></span>
                        </div>
                    </div>
                </div>

                <div class="bg-surface p-4 border border-outline-variant/30">
                    <h2 class="text-xs font-bold text-on-surface uppercase tracking-wider mb-4 border-b border-outline-variant/30 pb-2 text-primary">MUNITION_PAYLOAD</h2>
                    <div class="space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-widest block mb-1">DIA [MM] <span id="shaftWarnTxt" class="text-error text-[8px]"></span></label>
                                <select id="shaftDia" onchange="updateAll()" class="w-full"><option value="6.5">6.5</option><option value="7.0" selected>7.0</option><option value="7.5">7.5</option><option value="8.0">8.0</option></select>
                            </div>
                            <div>
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-widest block mb-1" data-i18n="flopper">FLOPPER</label>
                                <select id="flopperType" onchange="dynamicLimit(true); updateAll();" class="w-full"><option value="top">Top</option><option value="bottom" selected>Bottom</option><option value="double">Double</option><option value="slip">Slip Tip</option></select>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between items-end mb-1">
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-widest">SHAFT_LEN <span id="shaftHintTxt" class="text-[8px] text-on-surface-variant/50 ml-2"></span></label>
                                <span class="text-primary font-bold text-sm glow-text" id="shaftLenVal">130 cm</span>
                            </div>
                            <input type="range" id="shaftLen" step="5" oninput="document.getElementById('shaftLenWarn').style.display='none'; updateAll();">
                            <span id="shaftLenWarn" style="display:none;" class="text-[10px] text-error"></span>
                        </div>
                        
                        <div class="pt-2 border-t border-outline-variant/30">
                            <label class="text-[10px] text-on-surface-variant uppercase tracking-widest block mb-1" data-i18n="reel">REEL_MOD</label>
                            <select id="hasReel" onchange="toggleReelUI(); updateAll();" class="w-full mb-2"><option value="no" selected>No Reel</option><option value="yes">Attached</option></select>
                            <div id="uiReelConfig" style="display:none;" class="grid grid-cols-2 gap-4">
                                <select id="reelCap" onchange="updateAll()" class="w-full text-xs"><option value="30">30m</option><option value="50" selected>50m</option><option value="70">70m</option></select>
                                <select id="reelLine" onchange="updateAll()" class="w-full text-xs"><option value="1.5" selected>1.5mm</option><option value="2.0">2.0mm</option></select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-span-1 md:col-span-8 flex flex-col gap-4">
                
                <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                    <div class="bg-surface-container p-3 border-l-[3px] border-primary">
                        <p class="text-[10px] text-on-surface-variant uppercase">OVERALL_SCORE</p>
                        <p class="text-3xl text-primary font-bold mt-1 glow-text" id="resScore">0</p>
                        <p class="text-[9px] text-primary/70 uppercase mt-1" id="resRatingDesc">-</p>
                    </div>
                    <div class="bg-surface-container p-3 border-l-[3px] border-primary">
                        <p class="text-[10px] text-on-surface-variant uppercase">EST_THRUST</p>
                        <p class="text-2xl text-on-surface font-bold mt-1" id="resForce">0 <span class="text-xs text-on-surface-variant font-normal">KG</span></p>
                        <p class="text-[9px] text-on-surface-variant uppercase mt-1">MASS: <span id="resWeight"></span> KG</p>
                    </div>
                    <div class="bg-surface-container p-3 border-l-[3px] border-primary">
                        <p class="text-[10px] text-on-surface-variant uppercase">VELOCITY_@4M</p>
                        <p class="text-2xl text-on-surface font-bold mt-1" id="liveSpeed">0.0 <span class="text-xs text-on-surface-variant font-normal">M/S</span></p>
                        <p class="text-[9px] text-on-surface-variant uppercase mt-1">IMPACT_E: <span id="liveEnergy" class="text-primary font-bold">0</span> J</p>
                    </div>
                    <div class="bg-surface-container p-3 border-l-[3px] border-error">
                        <p class="text-[10px] text-error/80 uppercase">DROP_CALC</p>
                        <p class="text-2xl text-error font-bold mt-1 glow-text" id="liveDrop">0.0 <span class="text-xs text-error/70 font-normal">CM</span></p>
                        <p class="text-[9px] text-error uppercase mt-1 w-full truncate" id="aimGuideTxt">-</p>
                    </div>
                </div>

                <div class="bg-surface p-4 border border-outline-variant/30 flex-1 min-h-[250px] relative scanline-box flex flex-col">
                    <h2 class="text-xs font-bold text-on-surface uppercase tracking-wider mb-2 border-b border-outline-variant/30 pb-2 text-primary">BALLISTIC_TRAJECTORY_PLOT</h2>
                    <div id="chartContainer" class="flex-1 w-full relative mt-2 border-l border-b border-outline-variant/50">
                        <canvas id="trajCanvas"></canvas>
                    </div>
                    <div class="mt-4 flex items-center gap-4">
                        <span class="text-[10px] text-primary uppercase">SCRUB_DIST [M]:</span>
                        <input type="range" id="distScrubber" min="0" max="10" step="0.1" value="5" oninput="updateScrubber()" class="flex-1">
                        <span class="text-sm font-bold text-primary w-8 text-right glow-text" id="scrubDistTxt">5.0</span>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="bg-surface p-4 border border-outline-variant/30 flex flex-col items-center justify-center relative min-h-[220px] scanline-box">
                        <div class="absolute top-2 left-2 text-[8px] text-primary uppercase">RADAR_SWEEP // ACTIVE</div>
                        <div class="w-full h-full" id="radarWrap"><canvas id="radarCanvas"></canvas></div>
                        <div class="absolute bottom-2 w-full px-4 flex justify-between text-[8px] text-on-surface-variant">
                            <span>MAIN_CUT: <strong id="resCutLen" class="text-primary"></strong></span>
                            <span id="resSubLenBox" style="display:none;">SUB_CUT: <strong id="resSubLen" class="text-primary"></strong></span>
                        </div>
                    </div>
                    
                    <div class="bg-surface p-4 border border-outline-variant/30 flex flex-col">
                        <h3 class="text-[10px] font-bold text-primary uppercase tracking-wider mb-2 border-b border-outline-variant/30 pb-1">SYS_LOGS</h3>
                        <div id="sysLogs" class="flex-1 space-y-1 overflow-hidden font-mono text-[9px] flex flex-col-reverse">
                            </div>
                    </div>
                </div>
                
                <div style="display:none;">
                    <span id="idxPain"></span><span id="idxRecoil"></span><span id="idxSwing"></span><span id="idxBuoy"></span><span id="idxPort"></span>
                    <span id="eRcl"></span><span id="eBuy"></span><span id="eSwg"></span><span id="ePan"></span><span id="eEgy"></span><span id="eDrp"></span>
                </div>
            </div>
        </div>
    </main>
</div>

<div id="exportCanvas">
    <div class="exp-title">
        <span data-i18n="exp_title">MH_OPS TACTICAL DATASHEET</span>
        <div style="text-align:right;">
            <div style="font-size:36px; font-weight:900; color:#00fc40; line-height:1; text-shadow:0 0 10px #00fc40;" id="expScoreVal">0</div>
            <div style="font-size:10px; color:#fff;" data-i18n="total_score">COMBAT RATING</div>
        </div>
    </div>
    <div style="display:flex; justify-content:space-between; align-items:center; border:1px solid #00fc40; padding:10px; background:#131313; margin-bottom:15px;">
        <img id="expRadarImg" style="width:130px; height:130px;">
        <div style="flex:1; padding-left:15px; font-size:12px; line-height:1.6;">
            <div><strong data-i18n="idx_recoil" style="color:#00fc40">RECOIL</strong>: <span id="eRclOut"></span> | <strong data-i18n="idx_buoy" style="color:#00fc40">BUOYANCY</strong>: <span id="eBuyOut"></span></div>
            <div><strong data-i18n="idx_swing" style="color:#00fc40">SWING</strong>: <span id="eSwgOut"></span> | <strong data-i18n="idx_pain" style="color:#00fc40">LOAD</strong>: <span id="ePanOut"></span></div>
            <div style="margin-top:5px; color:#ff7351; font-weight:bold;">4M_IMPACT: <span id="eEgyOut"></span> J | DROP: <span id="eDrpOut"></span> CM</div>
        </div>
