function updateModels() { const b=document.getElementById('bandBrand').value, ms=document.getElementById('bandModel'); ms.innerHTML=''; bandDB[b].forEach(m=>{ let o=document.createElement('option'); o.value=m.val; o.innerText=m.name; if(m.sel) o.selected=true; ms.appendChild(o); }); }

function updateAll() {
    logCount++;
    const gl=parseFloat(document.getElementById('gunLen').value); document.getElementById('gunLenVal').innerText=gl;
    const sl=parseFloat(document.getElementById('shaftLen').value); document.getElementById('shaftLenVal').innerText=sl;
    const sys=document.getElementById('sysType').value;
    let wl=parseFloat(document.getElementById('wishboneLen').value); if(document.getElementById('autoWishbone').checked){ wl=10; document.getElementById('wishboneLen').value=wl; } document.getElementById('wishboneLenVal').innerText=wl;
    let el=parseFloat(document.getElementById('extLen').value); if(sys!=='standard'&&document.getElementById('autoExt').checked){ el=sys==='invert'?Math.round(gl*0.25):Math.round(gl*0.1); document.getElementById('extLen').value=el; }else if(sys==='standard')el=0; document.getElementById('extLenVal').innerText=el;
    
    const bd=document.getElementById('bandModel').value.split(','), bDia=parseFloat(bd[0]), bEla=parseFloat(bd[1]);
    const L=document.getElementById('lockBand').checked;
    let rM=parseFloat(document.getElementById('stretchRatio').value), rS=rM, cM=0, cS=0;

    if(L){ cM=parseFloat(document.getElementById('inputMainBand').value)||1; if(sys==='standard') rM=((gl-wl)*2)/cM; else if(sys==='invert') rM=Math.max(5,gl-wl-el)/cM; else rM=Math.max(5,gl*2+10-wl-el)/cM; if(sys==='invert'){ cS=parseFloat(document.getElementById('inputSubBand').value)||1; rS=(gl*1.6)/cS; } document.getElementById('stretchRatio').value=rM.toFixed(1);
    }else{ cM=sys==='standard'?((gl-wl)*2)/rM:(sys==='invert'?Math.max(5,gl-wl-el)/rM:Math.max(5,gl*2+10-wl-el)/rM); cS=sys==='invert'?(gl*1.6)/rS:0; }
    
    document.getElementById('stretchRatioVal').innerText=rM.toFixed(1)+"x";
    let rw="", rVeto=false; if(rM<2.5){ rw="["+t('warn_weak')+"]"; rVeto=true; }else if(rM>3.8){ rw="["+t('warn_break')+"]"; rVeto=true; } document.getElementById('ratioWarnTxt').innerText=rw;
    document.getElementById('resCutLen').innerText=cM.toFixed(1); document.getElementById('resSubLenBox').style.display=sys==='invert'?'inline':'none'; if(sys==='invert') document.getElementById('resSubLen').innerText=cS.toFixed(1);

    let fM=Math.pow(bDia/16,2)*(rM/3.3)*bEla*50, tF=0;
    if(sys==='standard') tF=fM*parseInt(document.getElementById('stdCount').value); else if(sys==='roller') tF=fM; else if(sys==='double_roller') tF=fM*2; else if(sys==='invert'){ let fS=Math.pow(bDia/16,2)*(rS/3.3)*bEla*50; tF=fM+(fS*parseInt(document.getElementById('invSubCount').value)); }
    document.getElementById('resForce').innerText=tF.toFixed(0);

    const sd=parseFloat(document.getElementById('shaftDia').value); let sVeto=false; if(tF>50&&sd<=6.5){ document.getElementById('shaftWarnTxt').innerText=t('warn_bend'); sVeto=true; }else document.getElementById('shaftWarnTxt').innerText="";

    const rho=1025, sm=Math.PI*Math.pow(sd/2000,2)*(sl/100)*7750, gs=document.getElementById('gunShape').value; let gv=0, gd=0;
    if(gs==='al_tube'){ gv=Math.PI*Math.pow(0.014,2)*(gl/100); gd=800; } if(gs==='carbon_cuttlefish'){ gv=0.05*0.03*0.8*(gl/100); gd=600; } if(gs==='wood_cuttlefish'){ gv=0.05*0.035*0.8*(gl/100); gd=720; } if(gs==='wood_block'){ gv=0.06*0.04*(gl/100); gd=750; }
    let tm=gv*gd+0.4+sm+(sys.includes('roller')?0.2:0)+(sys==='invert'?0.3:0);
    if(document.getElementById('hasReel').value==='yes') tm+=0.15+(parseInt(document.getElementById('reelCap').value)*(parseFloat(document.getElementById('reelLine').value)===1.5?0.0015:0.0025));
    let bal=(gv*rho)-tm>0.15?(gv*rho)-tm:0; tm+=bal; document.getElementById('resWeight').innerText=tm.toFixed(2);

    let iP=Math.max(1,Math.min(10,Math.round(11-(Math.pow(bDia/16,2)*(rM/3.0)*(gl/100)*5)*(sys==='invert'?0.5:1))));
    let iR=Math.max(1,Math.min(10,Math.round(11-((tF/50)*(sm/0.4)/(tm+1.5))*(sys==='invert'?0.2:(sys==='double_roller'?1.5:(sys==='roller'?0.8:1.0)))*4)));
    let iS=Math.max(1,Math.min(10,Math.round(10-((gl-60)/20)-(gs==='al_tube'?0:(gs==='carbon_cuttlefish'?0.5:2.5))+(sys==='invert'?2:0)-(document.getElementById('hasReel').value==='yes'?1:0))));
    let iB=Math.max(1,Math.min(10,Math.round(10-Math.abs(((gv*rho)-tm)*15))));
    let iPt=Math.max(1,Math.min(10,Math.round(15-(sl/30)-(tm*1.2))));

    // Store for export
    document.getElementById('idxPain').innerText=iP; document.getElementById('idxRecoil').innerText=iR; document.getElementById('idxSwing').innerText=iS; document.getElementById('idxBuoy').innerText=iB; document.getElementById('idxPort').innerText=iPt;

    let wd=Math.max(0.1,(gl-wl)/100), eng=tF*9.81*wd*0.5*(sys.includes('roller')?1.4:(sys==='invert'?1.5:1.0)), v0=Math.sqrt(2*eng/sm)*0.7;
    trajData=[]; let cV=v0, cT=0, e4=0, d4=0, bDrag=0.5*rho*Math.PI*Math.pow(sd/2000,2)*0.05*(document.getElementById('flopperType').value==='slip'?1.25:1.0), gE=9.81*(1-rho/7750)*(document.getElementById('flopperType').value==='top'?0.92:1.08);
    
    for(let x=0;x<=10;x+=0.1){ cV-=(bDrag/sm)*cV*cV*0.1; if(cV<0)cV=0; if(cV>0)cT+=0.1/cV; let d=0.5*gE*cT*cT*100, e=0.5*sm*cV*cV; trajData.push({dist:x,drop:d,speed:cV,energy:e}); if(Math.abs(x-4.0)<0.05){e4=e;d4=d;} }

    let twr=tF/sm, sc=0;
    if(rVeto||sVeto){ sc=Math.floor(Math.random()*10+25); document.getElementById('resScore').className="text-3xl text-error font-bold mt-1 glow-text"; document.getElementById('resRatingDesc').innerText="FATAL_ERR_DETECTED"; document.getElementById('resRatingDesc').className="text-[9px] text-error uppercase mt-1"; }
    else{
        sc=Math.min(100,Math.round(Math.min(15,(e4/30)*15)+Math.min(15,(5/Math.max(0.1,d4))*15)+(iR/10)*20+(iB/10)*20+Math.max(0,15-Math.abs(twr-250)/10)+(iS/10)*15));
        document.getElementById('resScore').className="text-3xl font-bold mt-1 glow-text text-primary"; document.getElementById('resRatingDesc').className="text-[9px] uppercase mt-1 text-primary";
