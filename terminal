function autoOptimize() { document.getElementById('lockBand').checked=false; toggleTuningMode(); const gl=parseFloat(document.getElementById('gunLen').value), s=document.getElementById('sysType').value; document.getElementById('bandBrand').value='sigalsub'; updateModels(); document.getElementById('flopperType').value='bottom'; document.getElementById('autoWishbone').checked=true; document.getElementById('autoExt').checked=true; if(s==='standard'){ document.getElementById('stdCount').value=gl<=85?'1':'2'; document.getElementById('bandModel').value=gl<=110&&gl>85?'14.5,1.18':'16,1.20'; document.getElementById('shaftDia').value=gl<=85?'6.5':(gl>110?'7.5':'7.0'); document.getElementById('stretchRatio').value=gl<=110&&gl>85?3.5:3.4; }else{ document.getElementById('bandModel').value=s==='double_roller'?'14.5,1.18':'16,1.20'; document.getElementById('shaftDia').value=gl>110?'8.0':'7.5'; document.getElementById('stretchRatio').value=3.6; } document.getElementById('shaftLen').value=gl+(s==='standard'?30:20); document.getElementById('shaftLenWarn').style.display='none'; dynamicLimit(false); updateSysUI(); sysLog("AUTO_SYNC_COMPLETE"); updateAll(); }

