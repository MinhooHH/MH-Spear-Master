    }
    currentScore=sc; document.getElementById('resScore').innerText=sc;
    
    if(logCount % 2 === 0) sysLog(`RECALC_OK: F=${tF.toFixed(0)}KG, E=${e4.toFixed(0)}J`);
    drawRadar([iP,iR,iS,iB,iPt]); drawCanvas(); updateScrubber(); prepareExportData();
}

function drawRadar(v=[1,1,1,1,1]) {
    const cvs=document.getElementById('radarCanvas'), ctx=cvs.getContext('2d'), dpr=window.devicePixelRatio||1, bw=cvs.parentElement.clientWidth, bh=cvs.parentElement.clientHeight;
    cvs.width=bw*dpr; cvs.height=bh*dpr; ctx.scale(dpr,dpr); ctx.clearRect(0,0,bw,bh); const cx=bw/2, cy=bh/2, r=Math.min(bw,bh)/2.5 - 10;
    ctx.strokeStyle='#494847'; ctx.lineWidth=1;
    for(let i=1;i<=5;i++){ ctx.beginPath(); for(let j=0;j<5;j++){ let a=-Math.PI/2+(Math.PI*2/5)*j, px=cx+Math.cos(a)*(r*i/5), py=cy+Math.sin(a)*(r*i/5); j===0?ctx.moveTo(px,py):ctx.lineTo(px,py); } ctx.closePath(); ctx.stroke(); }
    ctx.beginPath(); ctx.fillStyle='rgba(0, 252, 64, 0.2)'; ctx.strokeStyle='#00fc40'; ctx.lineWidth=1.5;
    for(let j=0;j<5;j++){ let a=-Math.PI/2+(Math.PI*2/5)*j, px=cx+Math.cos(a)*(r*v[j]/10), py=cy+Math.sin(a)*(r*v[j]/10); j===0?ctx.moveTo(px,py):ctx.lineTo(px,py); }
    ctx.closePath(); ctx.fill(); ctx.stroke();
    const L=[t('idx_pain'),t('idx_recoil'),t('idx_swing'),t('idx_buoy'),t('idx_port')]; ctx.font='bold 9px "Space Grotesk", sans-serif'; ctx.textAlign='center'; ctx.textBaseline='middle';
    for(let j=0;j<5;j++){ let a=-Math.PI/2+(Math.PI*2/5)*j, tR=r+12, px=cx+Math.cos(a)*tR, py=cy+Math.sin(a)*tR; ctx.fillStyle=v[j]<=3?'#ff7351':'#9cff93'; ctx.fillText(L[j],px,py); }
    document.getElementById('eRcl').innerText=v[1]; document.getElementById('eBuy').innerText=v[3]; document.getElementById('eSwg').innerText=v[2]; document.getElementById('ePan').innerText=v[0];
}

function drawCanvas() {
    const cvs=document.getElementById('trajCanvas'), ctx=cvs.getContext('2d'), r=cvs.parentElement.getBoundingClientRect(), dpr=window.devicePixelRatio||1;
    cvs.width=r.width*dpr; cvs.height=r.height*dpr; ctx.scale(dpr,dpr); const w=r.width, h=r.height; ctx.clearRect(0,0,w,h);
    ctx.fillStyle='rgba(0,252,64,0.5)'; ctx.font='9px "Space Grotesk", monospace'; ctx.textAlign='center';
    for(let i=1;i<10;i++){ let x=(w/10)*i; ctx.beginPath(); ctx.strokeStyle='rgba(73, 72, 71, 0.3)'; ctx.moveTo(x,15); ctx.lineTo(x,h); ctx.stroke(); ctx.fillText(i+'m',x,10); }
    ctx.strokeStyle='rgba(255, 115, 81, 0.3)'; ctx.setLineDash([2,4]); ctx.beginPath(); ctx.moveTo(0,15); ctx.lineTo(w,15); ctx.stroke(); ctx.setLineDash([]);
    ctx.beginPath(); ctx.strokeStyle='#00fc40'; ctx.lineWidth=2; ctx.moveTo(0,15); trajData.forEach(p=>ctx.lineTo((p.dist/10)*w, 15+(p.drop/100)*(h-30))); ctx.stroke();
    window.cSnap=ctx.getImageData(0,0,cvs.width,cvs.height);
}

function updateScrubber() {
    if(!trajData.length) return; const val=parseFloat(document.getElementById('distScrubber').value); document.getElementById('scrubDistTxt').innerText=val.toFixed(1);
    let p=trajData.reduce((pr,cu)=>Math.abs(cu.dist-val)<Math.abs(pr.dist-val)?cu:pr);
    document.getElementById('liveDrop').innerText=p.drop.toFixed(1); document.getElementById('liveSpeed').innerText=p.speed.toFixed(1); document.getElementById('liveEnergy').innerText=p.energy.toFixed(0);
    if(val===4.0||Math.abs(val-4.0)<0.1){ document.getElementById('eEgy').innerText=p.energy.toFixed(0); document.getElementById('eDrp').innerText=p.drop.toFixed(1); }
    const g=document.getElementById('aimGuideTxt');
    if(p.energy<25){ g.innerText=t('aim_warn'); g.className="text-[9px] text-error uppercase mt-1 w-full truncate glow-text animate-pulse"; }
    else{ g.className="text-[9px] text-primary uppercase mt-1 w-full truncate"; if(p.drop<=2.0) g.innerText=t('aim_0'); else if(p.drop<=7.0) g.innerText=t('aim_1'); else g.innerText=t('aim_2',(p.drop-7.0).toFixed(1)); }
    const cvs=document.getElementById('trajCanvas'), ctx=cvs.getContext('2d'), w=cvs.width/(window.devicePixelRatio||1), h=cvs.height/(window.devicePixelRatio||1);
    if(window.cSnap) ctx.putImageData(window.cSnap,0,0);
    let px=(p.dist/10)*w, py=15+(p.drop/100)*(h-30);
    ctx.beginPath(); ctx.setLineDash([2,2]); ctx.strokeStyle='#ff7351'; ctx.lineWidth=1; ctx.moveTo(px,15); ctx.lineTo(px,h); ctx.stroke(); ctx.setLineDash([]);
    ctx.beginPath(); ctx.arc(px,py,4,0,Math.PI*2); ctx.fillStyle='#ff7351'; ctx.fill();
}

function prepareExportData() {
    const sel=id=>document.getElementById(id).options[document.getElementById(id).selectedIndex].text;
    document.getElementById('expGun').innerText=`${document.getElementById('gunLen').value}CM / ${sel('sysType')} / ${sel('gunShape')}`;
    document.getElementById('expWeight').innerText=`${document.getElementById('resWeight').innerText} KG`;
    let ex=document.getElementById('sysType').value!=='standard'?` (EXT:${document.getElementById('extLen').value}CM)`:'';
    document.getElementById('expBandModel').innerText=`${sel('bandBrand')} - ${sel('bandModel')}`;
    document.getElementById('expBandData').innerText=`${document.getElementById('stretchRatioVal').innerText} / ${document.getElementById('resCutLen').innerText}${ex}`;
    document.getElementById('expForce').innerText=document.getElementById('resForce').innerText + " KG";
    document.getElementById('expShaft').innerText=`${document.getElementById('shaftLen').value}CM / ${sel('shaftDia')} / ${sel('flopperType')}`;
    
    document.getElementById('eRclOut').innerText=document.getElementById('eRcl').innerText; document.getElementById('eBuyOut').innerText=document.getElementById('eBuy').innerText;
    document.getElementById('eSwgOut').innerText=document.getElementById('eSwg').innerText; document.getElementById('ePanOut').innerText=document.getElementById('ePan').innerText;
    document.getElementById('eEgyOut').innerText=document.getElementById('eEgy').innerText; document.getElementById('eDrpOut').innerText=document.getElementById('eDrp').innerText;

    document.getElementById('expRadarImg').src=document.getElementById('radarCanvas').toDataURL('image/png',1.0);
    const sc=document.getElementById('expScoreVal'); sc.innerText=currentScore; sc.style.color=document.getElementById('resScore').classList.contains('text-error')?'#ff7351':'#00fc40';
}

function exportConfig() {
    sysLog("INITIATING_EXPORT...");
    if(typeof html2canvas==='undefined'){ sysLog("ERR: HTML2CANVAS_MISSING",true); return; }
    const tg=document.getElementById('exportCanvas'); tg.style.left='0'; tg.style.top='0'; tg.style.zIndex='-1';
    html2canvas(tg,{scale:2, backgroundColor:'#0e0e0e'}).then(c=>{
        tg.style.left='-9999px'; const imgD=c.toDataURL('image/png');
        if(/iPad|iPhone|iPod|MicroMessenger/i.test(navigator.userAgent)&&!window.MSStream){
            const ov=document.createElement('div'); ov.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.95);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;';
            const tp=document.createElement('div'); tp.innerText='LONG PRESS TO SAVE DATASHEET'; tp.className='text-primary font-bold mb-4 animate-pulse';
            const ig=document.createElement('img'); ig.src=imgD; ig.style.cssText='max-width:90%;max-height:80%;border:2px solid #00fc40;box-shadow:0 0 20px rgba(0,252,64,0.3);';
            ov.appendChild(tp); ov.appendChild(ig); ov.onclick=()=>document.body.removeChild(ov); document.body.appendChild(ov);
        }else{ const l=document.createElement('a'); l.download=`MH_OPS_DAT_${new Date().getTime()}.png`; l.href=imgD; l.click(); }
        sysLog("EXPORT_COMPLETE");
    }).catch(e=>{ tg.style.left='-9999px'; sysLog("ERR: RENDER_FAILED",true); });
}

window.onload = initUI;
